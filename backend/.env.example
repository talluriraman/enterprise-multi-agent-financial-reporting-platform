# Copy to .env for local runs (never commit secrets).

OBO_REQUIRE_AUTH=false
OBO_AUDIENCE=api://financial-reporting-platform

# Azure OpenAI / AI Foundry (OpenAI-compatible). Leave empty for offline demo mode.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_CHAT_DEPLOYMENT=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Platform → Azure: set true in AKS with workload identity / managed identity
USE_MANAGED_IDENTITY=false

# Tools call internal APIs via APIM base URL (same host in local POC)
APIM_BASE_URL=http://127.0.0.1:8000
APIM_SUBSCRIPTION_KEY=

SQLITE_PATH=./data/platform_memory.sqlite3
DEMO_MODE=true
